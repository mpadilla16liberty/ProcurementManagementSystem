
@*
Procurement Tracking Tool
    CSIS 483 Capstone Project
    Moses Padilla

    Purpose:
    This page displays submitted purchase requests and allows procurement personnel to review, approve, or reject requests. It serves as the approval stage 
    of the procurement workflow and provides visibility into the status of each request.

    Functionality:
    - Displays all submitted purchase requests.
    - Shows vendor, item, cost, end-user, and status information.
    - Formats procurement costs as U.S. currency.
    - Allows users to approve purchase requests.
    - Allows users to reject purchase requests.
    - Provides navigation back to the application home page.

    Notes:
    This page utilizes ASP.NET Core Razor syntax to display purchase request data stored within the application. Bootstrap table
    components and button controls are used to improve readability and provide user-friendly navigation and approval actions.

    References:
    Carey, P. M. (2020). New perspectives on HTML5 and CSS3: Comprehensive (8th ed.). Cengage Learning.

    Microsoft. (n.d.). Razor syntax reference for ASP.NET Core. https://learn.microsoft.com/en-us/aspnet/core/mvc/views/razor
*@


@model List<ProcurementTrackingTool.Models.PurchaseRequest>

@{
    ViewData["Title"] = "View and Approve Purchase Requests";
}

<h2>View/Approve Purchase Requests</h2>

<a asp-action="Index" class="btn btn-secondary mb-3">Back Home</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Vendor</th>
            <th>Item</th>
            <th>Cost</th>
            <th>End User</th>
            <th>Email</th>
            <th>Status</th>
            <th>Approval Action</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var request in Model)
        {
            <tr>
                <td>@request.Id</td>
                <td>@request.VendorName</td>
                <td>@request.ItemName</td>
                <td>$@request.Cost.ToString("N2")</td>
                <td>@request.EndUserName</td>
                <td>@request.EndUserEmail</td>
                <td>@request.Status</td>
                <td>

    @if (request.Status != "Approved")
    {
        <a class="btn btn-success btn-sm"
           asp-action="ApproveRequest"
           asp-route-id="@request.Id">
            Approve
        </a>
    }

    @if (request.Status != "Rejected")
    {
        <a class="btn btn-danger btn-sm"
           asp-action="RejectRequest"
           asp-route-id="@request.Id">
            Reject
        </a>
    }

    @if (request.Status == "Approved")
    {
        <a class="btn btn-primary btn-sm"
           asp-action="PrintPurchaseOrder"
           asp-route-id="@request.Id">
            Print PO
        </a>
    }

</td>
            </tr>
        }
    </tbody>
</table>
